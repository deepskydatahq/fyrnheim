---
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>fyrnheim — Define typed Python entities, generate transformations, run anywhere</title>
  <meta name="description" content="A Python-native dbt alternative built on Pydantic + Ibis. Define typed entities, generate transformations, run on any backend." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Skranji:wght@400;700&display=swap" rel="stylesheet" />
</head>
<body>
  <!-- Navigation -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">fyrnheim</a>
      <div class="nav-links">
        <a href="/getting-started/introduction/">Docs</a>
        <a href="https://github.com/deepskydatahq/fyrnheim" target="_blank" rel="noopener">GitHub</a>
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-overlay"></div>
    <canvas id="sparks" class="hero-sparks"></canvas>
    <div class="hero-content">
      <h1 class="hero-title">Forge Data Entities<br />from Raw Sources</h1>
      <p class="hero-subtitle">Forge typed entities from raw data. A Python-native dbt alternative built on Pydantic + Ibis. No SQL, no Jinja, no vendor lock-in.</p>
      <div class="hero-install">
        <code>pip install fyrnheim[duckdb]</code>
      </div>
      <div class="hero-actions">
        <a href="/getting-started/introduction/" class="btn btn-primary">Get Started</a>
        <a href="https://github.com/deepskydatahq/fyrnheim" class="btn btn-secondary" target="_blank" rel="noopener">View on GitHub</a>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="features">
    <div class="container">
      <h2 class="section-title">Built for Python-first data teams</h2>
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
          </div>
          <h3>Typed Entities</h3>
          <p>Define business objects as Pydantic models. Type safety and validation at definition time, not runtime.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>
          </div>
          <h3>Multi-Backend</h3>
          <p>Same entity runs on DuckDB locally and deploys to BigQuery, ClickHouse, or Postgres with zero changes via Ibis.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
          </div>
          <h3>Local Dev</h3>
          <p>Run transformations on local parquet files with DuckDB. No warehouse connection needed for development.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><polyline points="13 2 13 9 20 9"/></svg>
          </div>
          <h3>No SQL / No Jinja</h3>
          <p>Pure Python from entity definition to execution. Reusable functions replace SQL snippets and Jinja macros.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Code Walkthrough -->
  <section class="walkthrough">
    <div class="container">
      <h2 class="section-title">Four steps from raw data to insights</h2>
      <div class="steps">
        <div class="step">
          <div class="step-header">
            <span class="step-number">1</span>
            <h3>Initialize a project</h3>
          </div>
          <div class="code-block">
            <div class="code-bar"><span class="code-dot"></span><span class="code-dot"></span><span class="code-dot"></span><span class="code-label">terminal</span></div>
            <pre><code>$ fyr init myproject && cd myproject

Created myproject/
  created  entities/
  created  data/
  created  generated/
  created  fyrnheim.yaml
  created  entities/customers.py
  created  data/customers.parquet</code></pre>
          </div>
        </div>

        <div class="step">
          <div class="step-header">
            <span class="step-number">2</span>
            <h3>Define an Entity as Pydantic Object</h3>
          </div>
          <div class="code-block">
            <div class="code-bar"><span class="code-dot"></span><span class="code-dot"></span><span class="code-dot"></span><span class="code-label">entities/customers.py</span></div>
            <pre><code>entity = Entity(
    name="customers",
    source=TableSource(..., duckdb_path="customers.parquet"),
    layers=LayersConfig(
        prep=PrepLayer(
            model_name="prep_customers",
            computed_columns=[
                ComputedColumn(name="email_hash",
                    expression=hash_email("email")),
                ComputedColumn(name="amount_dollars",
                    expression="t.amount_cents / 100.0"),
            ],
        ),
        dimension=DimensionLayer(
            model_name="dim_customers",
            computed_columns=[
                ComputedColumn(name="is_paying",
                    expression="t.plan != 'free'"),
            ],
        ),
    ),
    quality=QualityConfig(
        checks=[NotNull("email"), Unique("email_hash")]
    ),
)</code></pre>
          </div>
        </div>

        <div class="step">
          <div class="step-header">
            <span class="step-number">3</span>
            <h3>Generate transformation code</h3>
          </div>
          <div class="code-block">
            <div class="code-bar"><span class="code-dot"></span><span class="code-dot"></span><span class="code-dot"></span><span class="code-label">terminal</span></div>
            <pre><code>$ fyr generate

Generating transforms from entities
  customers  generated/customers_transforms.py  written

Generated: 1 written, 0 unchanged</code></pre>
          </div>
        </div>

        <div class="step">
          <div class="step-header">
            <span class="step-number">4</span>
            <h3>Run the pipeline</h3>
          </div>
          <div class="code-block">
            <div class="code-bar"><span class="code-dot"></span><span class="code-dot"></span><span class="code-dot"></span><span class="code-label">terminal</span></div>
            <pre><code>$ fyr run

Discovering entities... 1 found
Running on duckdb

  customers  prep -> dim  12 rows  0.1s  ok

Done: 1 success, 0 errors (0.2s)</code></pre>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Comparison Table -->
  <section class="comparison">
    <div class="container">
      <h2 class="section-title">Why <span class="brand-name">fyrnheim</span> over dbt?</h2>
      <div class="table-wrapper">
        <table class="comparison-table">
          <thead>
            <tr>
              <th></th>
              <th>dbt</th>
              <th class="highlight-col"><span class="brand-name">fyrnheim</span></th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="row-label">Language</td>
              <td>SQL + Jinja</td>
              <td class="highlight-col">Python</td>
            </tr>
            <tr>
              <td class="row-label">Type safety</td>
              <td>Runtime errors</td>
              <td class="highlight-col">Pydantic validation at definition time</td>
            </tr>
            <tr>
              <td class="row-label">Local dev</td>
              <td>Needs multi-source config</td>
              <td class="highlight-col">DuckDB on local parquet files</td>
            </tr>
            <tr>
              <td class="row-label">Backend portability</td>
              <td>Dialect-specific SQL</td>
              <td class="highlight-col">Ibis compiles to 15+ backends</td>
            </tr>
            <tr>
              <td class="row-label">Testing</td>
              <td>Custom schema tests</td>
              <td class="highlight-col">pytest + quality checks</td>
            </tr>
            <tr>
              <td class="row-label">Boilerplate</td>
              <td>Jinja macros, YAML configs</td>
              <td class="highlight-col">Python functions, Pydantic models</td>
            </tr>
            <tr>
              <td class="row-label">Identity resolution</td>
              <td>Manual SQL joins</td>
              <td class="highlight-col">Built-in identity graph (DerivedSource)</td>
            </tr>
            <tr>
              <td class="row-label">Multi-source union</td>
              <td>Manual UNION ALL</td>
              <td class="highlight-col">UnionSource with field mapping</td>
            </tr>
            <tr>
              <td class="row-label">AI agents</td>
              <td>Limited with data models</td>
              <td class="highlight-col">Love typed objects</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Bottom Illustration -->
  <section class="bottom-illustration">
    <img src="/fyrnheim_bottom.png" alt="Fyrnheim volcanic forge illustration" />
  </section>

  <!-- Footer CTA -->
  <footer class="footer">
    <div class="container">
      <div class="footer-cta">
        <h2>Ready to forge your data entities?</h2>
        <p>Get started with <span class="brand-name">fyrnheim</span> in minutes. Define entities in Python, run locally on DuckDB, deploy anywhere.</p>
        <div class="footer-actions">
          <a href="/getting-started/introduction/" class="btn btn-primary">Get Started</a>
          <a href="https://github.com/deepskydatahq/fyrnheim" class="btn btn-secondary" target="_blank" rel="noopener">GitHub Repository</a>
        </div>
      </div>
      <div class="footer-bottom">
        <p><span class="brand-name">fyrnheim</span> is open source under the MIT License.</p>
      </div>
    </div>
  </footer>
</body>
</html>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    background: #0a0a0a;
    color: #f5f5f5;
    line-height: 1.6;
  }

  code {
    font-family: 'JetBrains Mono', monospace;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Navigation */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(10, 10, 10, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(245, 158, 11, 0.15);
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 2rem;
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
  }

  .nav-logo {
    font-family: 'Skranji', cursive;
    font-size: 1.5rem;
    font-weight: 400;
    color: #f4442e;
    text-decoration: none;
    letter-spacing: 0.05em;
  }

  .brand-name {
    font-family: 'Skranji', cursive;
    letter-spacing: 0.05em;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
    position: absolute;
    right: 2rem;
  }

  .nav-links a {
    color: #a3a3a3;
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
    transition: color 0.2s;
  }

  .nav-links a:hover {
    color: #f4442e;
  }

  /* Hero */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 6rem 2rem 4rem;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background-image: url('/images/hero-bg.png');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .hero-sparks {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(10, 10, 10, 0.7) 0%,
      rgba(10, 10, 10, 0.85) 50%,
      rgba(10, 10, 10, 0.95) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 800px;
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
    background: linear-gradient(135deg, #f5f5f5 0%, #d4d4d4 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    color: #a3a3a3;
    max-width: 600px;
    margin: 0 auto 2rem;
    line-height: 1.7;
  }

  .hero-install {
    display: inline-block;
    background: rgba(245, 158, 11, 0.08);
    border: 1px solid rgba(245, 158, 11, 0.25);
    border-radius: 8px;
    padding: 0.75rem 1.5rem;
    margin-bottom: 2rem;
  }

  .hero-install code {
    color: #f4442e;
    font-size: 1.05rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.85rem 2rem;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
    cursor: pointer;
  }

  .btn-primary {
    background: #f4442e;
    color: #0a0a0a;
  }

  .btn-primary:hover {
    background: #d63520;
    transform: translateY(-1px);
    box-shadow: 0 4px 24px rgba(245, 158, 11, 0.3);
  }

  .btn-secondary {
    background: transparent;
    color: #f5f5f5;
    border: 1px solid rgba(245, 245, 245, 0.2);
  }

  .btn-secondary:hover {
    border-color: rgba(245, 158, 11, 0.5);
    color: #f4442e;
  }

  /* Features */
  .features {
    padding: 6rem 0;
    background: #0a0a0a;
  }

  .section-title {
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 700;
    text-align: center;
    margin-bottom: 3.5rem;
    letter-spacing: -0.02em;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .feature-card {
    position: relative;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    padding: 2rem;
    transition: all 0.4s ease;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .feature-card::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: 16px;
    padding: 1px;
    background: linear-gradient(
      160deg,
      rgba(244, 68, 46, 0.0) 0%,
      rgba(244, 68, 46, 0.06) 50%,
      rgba(244, 68, 46, 0.0) 100%
    );
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    transition: all 0.4s ease;
  }

  .feature-card::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 16px;
    opacity: 0;
    transition: opacity 0.4s ease;
    background: radial-gradient(
      ellipse at 50% 100%,
      rgba(244, 68, 46, 0.12) 0%,
      rgba(255, 107, 53, 0.06) 40%,
      transparent 70%
    );
    pointer-events: none;
  }

  .feature-card:hover {
    border-color: rgba(244, 68, 46, 0.25);
    background: rgba(255, 255, 255, 0.04);
    transform: translateY(-4px);
    box-shadow:
      0 0 20px rgba(244, 68, 46, 0.1),
      0 0 60px rgba(244, 68, 46, 0.05),
      0 8px 32px rgba(0, 0, 0, 0.4);
  }

  .feature-card:hover::before {
    background: linear-gradient(
      160deg,
      rgba(244, 68, 46, 0.3) 0%,
      rgba(255, 140, 66, 0.15) 30%,
      rgba(244, 68, 46, 0.3) 60%,
      rgba(255, 107, 53, 0.1) 100%
    );
  }

  .feature-card:hover::after {
    opacity: 1;
  }

  .feature-icon {
    color: #f4442e;
    margin-bottom: 0.25rem;
    position: relative;
    z-index: 1;
  }

  .feature-card h3 {
    font-size: 1.2rem;
    font-weight: 600;
    position: relative;
    z-index: 1;
  }

  .feature-card p {
    color: #a3a3a3;
    font-size: 0.9rem;
    line-height: 1.6;
    position: relative;
    z-index: 1;
  }

  /* Walkthrough */
  .walkthrough {
    padding: 6rem 0;
    background: #0f0f0f;
  }

  .steps {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .step-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .step-number {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(245, 158, 11, 0.15);
    color: #f4442e;
    font-weight: 700;
    font-size: 1rem;
    flex-shrink: 0;
  }

  .step-header h3 {
    font-size: 1.2rem;
    font-weight: 600;
  }

  .code-block {
    background: #141414;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 10px;
    overflow: hidden;
  }

  .code-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 0.75rem 1rem;
    background: rgba(255, 255, 255, 0.03);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .code-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
  }

  .code-label {
    margin-left: auto;
    font-size: 0.8rem;
    color: #737373;
    font-family: 'JetBrains Mono', monospace;
  }

  .code-block pre {
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
  }

  .code-block code {
    font-size: 0.875rem;
    line-height: 1.7;
    color: #d4d4d4;
  }

  /* Comparison */
  .comparison {
    padding: 6rem 0;
    background: #0a0a0a;
  }

  .table-wrapper {
    max-width: 900px;
    margin: 0 auto;
    overflow-x: auto;
    padding: 0 2rem;
  }

  .comparison-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.95rem;
  }

  .comparison-table th,
  .comparison-table td {
    padding: 1rem 1.25rem;
    text-align: left;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .comparison-table thead th {
    font-weight: 700;
    font-size: 1.1rem;
    padding-bottom: 1.25rem;
    border-bottom: 2px solid rgba(255, 255, 255, 0.1);
  }

  .comparison-table .highlight-col {
    background: rgba(245, 158, 11, 0.05);
    color: #fca5a5;
  }

  .comparison-table thead .highlight-col {
    color: #f4442e;
  }

  .comparison-table .row-label {
    font-weight: 600;
    color: #e5e5e5;
    white-space: nowrap;
  }

  .comparison-table td:not(.row-label):not(.highlight-col) {
    color: #a3a3a3;
  }

  /* Bottom Illustration */
  .bottom-illustration {
    background: #0a0a0a;
    text-align: center;
    padding: 0;
    margin: 0;
    line-height: 0;
  }

  .bottom-illustration img {
    max-width: 420px;
    width: 100%;
    height: auto;
    opacity: 0.85;
    transition: opacity 0.4s ease, filter 0.4s ease;
    filter: drop-shadow(0 0 0px transparent);
  }

  .bottom-illustration img:hover {
    opacity: 1;
    filter: drop-shadow(0 0 20px rgba(244, 68, 46, 0.5)) drop-shadow(0 0 60px rgba(245, 158, 11, 0.3));
  }

  /* Footer */
  .footer {
    padding: 6rem 0 2rem;
    background: #0f0f0f;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .footer-cta {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 4rem;
  }

  .footer-cta h2 {
    font-size: clamp(1.5rem, 3.5vw, 2.2rem);
    font-weight: 700;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .footer-cta p {
    color: #a3a3a3;
    font-size: 1.1rem;
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  .footer-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .footer-bottom {
    text-align: center;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .footer-bottom p {
    color: #525252;
    font-size: 0.875rem;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero {
      padding: 5rem 1.5rem 3rem;
    }

    .features-grid {
      grid-template-columns: 1fr;
    }

    .nav-links {
      gap: 1rem;
    }

    .comparison-table {
      font-size: 0.85rem;
    }

    .comparison-table th,
    .comparison-table td {
      padding: 0.75rem;
    }
  }
</style>

<script>
  const canvas = document.getElementById('sparks') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  const hero = canvas.parentElement!;

  function resize() {
    canvas.width = hero.offsetWidth;
    canvas.height = hero.offsetHeight;
  }
  resize();
  window.addEventListener('resize', resize);

  interface Spark {
    x: number;
    y: number;
    vx: number;
    vy: number;
    size: number;
    life: number;
    maxLife: number;
    flicker: number;
  }

  const sparks: Spark[] = [];

  function spawn() {
    sparks.push({
      x: Math.random() * canvas.width,
      y: canvas.height + 4,
      vx: (Math.random() - 0.5) * 0.6,
      vy: -(0.3 + Math.random() * 1.2),
      size: 1 + Math.random() * 2.5,
      life: 0,
      maxLife: 120 + Math.random() * 180,
      flicker: Math.random() * Math.PI * 2,
    });
  }

  function animate() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    if (sparks.length < 60) {
      spawn();
      if (Math.random() > 0.5) spawn();
    }

    for (let i = sparks.length - 1; i >= 0; i--) {
      const s = sparks[i];
      s.x += s.vx + Math.sin(s.life * 0.02) * 0.3;
      s.y += s.vy;
      s.life++;
      s.flicker += 0.15;

      const progress = s.life / s.maxLife;
      const alpha = progress < 0.1
        ? progress * 10
        : 1 - ((progress - 0.1) / 0.9);

      if (s.life >= s.maxLife) {
        sparks.splice(i, 1);
        continue;
      }

      const flick = 0.7 + Math.sin(s.flicker) * 0.3;
      const coreSize = s.size * (1 - progress * 0.5);

      // Outer flame glow (large, soft)
      const g3 = ctx.createRadialGradient(s.x, s.y, 0, s.x, s.y, coreSize * 8);
      g3.addColorStop(0, `rgba(244, 68, 46, ${alpha * flick * 0.08})`);
      g3.addColorStop(1, 'rgba(244, 68, 46, 0)');
      ctx.fillStyle = g3;
      ctx.beginPath();
      ctx.arc(s.x, s.y, coreSize * 8, 0, Math.PI * 2);
      ctx.fill();

      // Mid glow (warm orange)
      const g2 = ctx.createRadialGradient(s.x, s.y, 0, s.x, s.y, coreSize * 4);
      g2.addColorStop(0, `rgba(255, 140, 66, ${alpha * flick * 0.25})`);
      g2.addColorStop(0.5, `rgba(255, 107, 53, ${alpha * flick * 0.1})`);
      g2.addColorStop(1, 'rgba(255, 107, 53, 0)');
      ctx.fillStyle = g2;
      ctx.beginPath();
      ctx.arc(s.x, s.y, coreSize * 4, 0, Math.PI * 2);
      ctx.fill();

      // Inner glow (bright)
      const g1 = ctx.createRadialGradient(s.x, s.y, 0, s.x, s.y, coreSize * 2);
      g1.addColorStop(0, `rgba(255, 224, 178, ${alpha * flick * 0.6})`);
      g1.addColorStop(0.4, `rgba(255, 173, 96, ${alpha * flick * 0.3})`);
      g1.addColorStop(1, 'rgba(244, 68, 46, 0)');
      ctx.fillStyle = g1;
      ctx.beginPath();
      ctx.arc(s.x, s.y, coreSize * 2, 0, Math.PI * 2);
      ctx.fill();

      // Hot white core
      const g0 = ctx.createRadialGradient(s.x, s.y, 0, s.x, s.y, coreSize);
      g0.addColorStop(0, `rgba(255, 255, 240, ${alpha * flick * 0.9})`);
      g0.addColorStop(1, `rgba(255, 200, 150, ${alpha * flick * 0.4})`);
      ctx.fillStyle = g0;
      ctx.beginPath();
      ctx.arc(s.x, s.y, coreSize, 0, Math.PI * 2);
      ctx.fill();
    }

    requestAnimationFrame(animate);
  }

  animate();
</script>
